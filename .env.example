# GEMINI_API_KEY: Required for Gemini AI API calls (if used)
GEMINI_API_KEY=""

# APP_URL: The URL where the frontend app is hosted
APP_URL="http://localhost:3000"

# SUPABASE_URL: The base URL of your Supabase project (e.g., https://xxx.supabase.co)
# IMPORTANT: Do NOT include the '/rest/v1/' suffix at the end!
SUPABASE_URL="https://your-project-id.supabase.co"

# SUPABASE_ANON_KEY: The public anon key for your Supabase project (Project Settings > API)
SUPABASE_ANON_KEY="your-anon-key-here"

# PORT: The port that the Express backend server will listen on
PORT=5000
